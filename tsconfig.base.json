{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "types": ["node"],
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@chronarium/types": ["packages/types/src/index.ts"],
      "@chronarium/schemas": ["packages/schemas/src/index.ts"],
      "@chronarium/archive": ["packages/archive/src/index.ts"],
      "@chronarium/core": ["packages/core/src/index.ts"],
      "@chronarium/indexer": ["packages/indexer/src/index.ts"],
      "@chronarium/media-tools": ["packages/media-tools/src/index.ts"],
      "@chronarium/player": ["packages/player/src/index.ts"],
      "@chronarium/desktop": ["apps/desktop/src/index.ts"],
      "@chronarium/adapter-kit": ["packages/adapters/kit/src/index.ts"],
      "@chronarium/adapter-chaturbate": [
        "packages/adapters/chaturbate/src/index.ts"
      ],
      "@chronarium/adapter-stripchat": [
        "packages/adapters/stripchat/src/index.ts"
      ],
      "@chronarium/testkit": ["packages/testkit/src/index.ts"]
    }
  }
}
